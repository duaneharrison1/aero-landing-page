---
import Layout from "../layouts/Layout.astro";
import Container from "../components/container.astro";

const APP_URL = "https://aeroapp.ai";

// NOTE: Placeholder Aero copy — to be refined later.
const steps = [
  {
    n: 1,
    title: "Build",
    body: "Build your prototype however you like — by hand, with an AI agent, or in Figma. Aero meets your work where it already is.",
  },
  {
    n: 2,
    title: "Host",
    body: "Publish it to a live URL by drag-and-drop, from an AI agent over MCP, or from a Figma link. Versioning lets you update and roll back.",
  },
  {
    n: 3,
    title: "Test",
    body: "Set up a task-based user test on your real hosted prototype. Real people try it while their screen and voice are recorded.",
  },
  {
    n: 4,
    title: "Learn",
    body: "Get transcripts and AI insights from every session, handed straight back to you — or to the agent that built the prototype.",
  },
];
---

<Layout title="How it works">
  <Container>
    <section class="bg-white pt-8 pb-4 md:pt-14 md:pb-6">
      <div class="text-center mt-14 mb-12">
        <h1 class="text-5xl md:text-6xl font-bold mb-3 text-[#1D1D1F]">
          How it works
        </h1>
        <p class="text-base md:text-lg text-[#6B6F76]">
          Placeholder copy — the build, host, test, learn loop.
        </p>
      </div>
      <div class="space-y-6 md:space-y-8 max-w-3xl mx-auto">
        {
          steps.map((step) => (
            <div class="flex flex-col md:flex-row items-start gap-4 md:gap-6 bg-[#F9FAFB] border border-subtle rounded-lg p-6 md:p-8">
              <div class="w-12 h-12 rounded-lg bg-[#3D78B0] text-white flex items-center justify-center text-2xl font-bold flex-shrink-0">
                {step.n}
              </div>
              <div>
                <h2 class="font-semibold text-xl md:text-2xl mb-2 text-[#1D1D1F]">
                  {step.title}
                </h2>
                <p class="text-base md:text-lg text-[#6B6F76] leading-relaxed">
                  {step.body}
                </p>
              </div>
            </div>
          ))
        }
      </div>

      <div class="flex justify-center mt-12">
        <a href={APP_URL} class="btn-primary px-8 py-3 font-semibold text-lg">
          Get started free
        </a>
      </div>
    </section>
  </Container>
</Layout>
