---
import Layout from "../layouts/Layout.astro";
import Container from "../components/container.astro";
import PricingTableNew from "../components/PricingTableNew.astro";
---

<Layout title="Pricing">
  <Container>
    <section class="bg-white pt-8 pb-4 md:pt-14 md:pb-6">
      <div class="max-w-3xl mx-auto text-center mt-14 mb-10">
        <h1 class="text-5xl md:text-6xl font-bold mb-3 text-[#1D1D1F]">
          Pricing
        </h1>
        <p class="text-xl text-[#6B6F76]">
          Start free. Publish prototypes to live URLs and run recorded user
          tests with AI insights. Try it free and cancel anytime during the
          trial period.
        </p>
      </div>

      <PricingTableNew />
    </section>

    <p class="text-center text-[#8E8E93] text-sm mt-10">
      Questions about a plan?{" "}
      <a href="/contact" class="text-[#3D78B0] hover:underline">
        Get in touch
      </a>
      .
    </p>
  </Container>
</Layout>
