---
import Layout from "../layouts/Layout.astro";
import Container from "../components/container.astro";

const APP_URL = "https://aeroapp.ai";

// NOTE: Placeholder Aero copy. The previous figmafolio pricing table pulled
// live plan/price data from figmafolio's backend, so it has been removed rather
// than shown with the wrong brand's plans. Real Aero pricing to be added later.
---

<Layout title="Pricing">
  <Container>
    <section class="bg-white pt-8 pb-4 md:pt-14 md:pb-6">
      <div class="max-w-3xl mx-auto text-center mt-14 mb-8">
        <h1 class="text-5xl md:text-6xl font-bold mb-3 text-[#1D1D1F]">
          Pricing
        </h1>
        <p class="text-xl text-[#6B6F76] mb-2">
          Placeholder — pricing details to be refined.
        </p>
        <p class="text-base text-[#6B6F76]">
          Aero lets you publish prototypes to live URLs and run recorded user
          tests on them. Plans and prices will be published here soon. In the
          meantime you can sign up free and start hosting.
        </p>
      </div>

      <div class="max-w-md mx-auto glass-card p-8 text-center mt-10">
        <h2 class="font-semibold text-2xl text-[#1D1D1F] mb-2">
          Get started free
        </h2>
        <p class="text-[#6B6F76] mb-6">
          Create an account, publish a prototype, and try a user test.
        </p>
        <a href={APP_URL} class="btn-primary px-8 py-3 font-semibold text-lg">
          Create your account
        </a>
      </div>
    </section>
  </Container>
</Layout>
