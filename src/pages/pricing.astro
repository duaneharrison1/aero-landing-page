---
import Layout from "../layouts/Layout.astro";
import Container from "../components/container.astro";
---

<Layout title="Pricing">
  <Container>
    <div class="max-w-2xl mx-auto mt-20 mb-10 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-[#1D1D1F] mb-4">Pricing</h1>
      <p class="text-[#6B6F76] text-lg leading-relaxed">
        [Placeholder: Aero pricing tiers to be confirmed. Sign up free to get started. Paid plans unlock additional hosted projects, more user test sessions, and advanced AI insight features.]
      </p>
    </div>

    <div class="max-w-xl mx-auto mb-24 p-8 bg-[#F9FAFB] rounded-lg border border-[rgba(0,0,0,0.06)] text-center">
      <p class="text-[#6B6F76] text-sm mb-6">Pricing details are being finalized. Get early access and we will let you know when plans are live.</p>
      <a
        href="https://aeroapp.ai"
        class="inline-flex items-center justify-center bg-[#3D78B0] text-white font-semibold text-sm px-5 py-2.5 rounded-lg shadow-[0_2px_8px_rgba(61,120,176,0.15)] hover:bg-[#2F6499] transition-colors duration-150"
      >
        Sign up free
      </a>
    </div>
  </Container>
</Layout>
