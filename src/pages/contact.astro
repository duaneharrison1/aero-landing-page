---
import Contactform from "../components/contactform.astro";
import Container from "../components/container.astro";
import Sectionhead from "../components/sectionhead.astro";
import Layout from "../layouts/Layout.astro";

// NOTE: Placeholder Aero copy — to be refined later. The previous figmafolio
// FAQ, LinkedIn link, and support email have been removed.
---

<Layout title="Contact">
  <Container>
    <div class="text-center mt-16 mb-10">
      <h1 class="text-4xl md:text-5xl font-bold mb-2 text-[#1D1D1F]">
        Get in touch
      </h1>
      <div class="text-lg text-[#6B6F76]">
        Placeholder copy — we’re here to help. Reach out anytime.
      </div>
    </div>

    <div id="contact-form" class="scroll-mt-24">
      <Sectionhead>
        <Fragment slot="title">Contact form</Fragment>
        <Fragment slot="desc"
          >Fill out the form below and we’ll get back to you.</Fragment
        >
      </Sectionhead>
      <div class="max-w-xl mx-auto mt-8">
        <Contactform />
      </div>
    </div>
  </Container>
</Layout>
