---
import Container from "../components/container.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout title="Contact">
  <Container>
    <div class="max-w-xl mx-auto mt-20 mb-24">
      <h1 class="text-4xl md:text-5xl font-bold text-[#1D1D1F] mb-4">Contact</h1>
      <p class="text-[#6B6F76] text-lg leading-relaxed mb-8">
        [Placeholder: Aero contact details to be added. For now, reach us at the link below.]
      </p>
      <a
        href="https://aeroapp.ai"
        class="inline-flex items-center justify-center bg-[#3D78B0] text-white font-semibold text-sm px-5 py-2.5 rounded-lg shadow-[0_2px_8px_rgba(61,120,176,0.15)] hover:bg-[#2F6499] transition-colors duration-150"
      >
        Go to aeroapp.ai
      </a>
    </div>
  </Container>
</Layout>
