---
import { SEO } from "astro-seo";
import Footer from "../components/Footer.astro";
import Navbar from "../components/navbar/navbar.astro";
import "@/styles/global.css";

export interface Props {
  title: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();

const resolvedImageWithDomain = new URL(
  "/opengraph.jpg",
  Astro.site
).toString();

const { title } = Astro.props;

const makeTitle = title
  ? title + " | " + "Aero"
  : "Aero — Publish prototypes, run user tests, get AI insights";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <SEO
      title={makeTitle}
      description="Publish prototypes by drag-drop, AI agent, or Figma link. Run recorded user tests. Get AI insights. The build-host-test loop in one place."
      canonical={canonicalURL}
      twitter={{
        creator: "@aeroapp",
        site: "@aeroapp",
        card: "summary_large_image",
      }}
      openGraph={{
        basic: {
          url: canonicalURL,
          type: "website",
          title: `Aero — Publish prototypes, run user tests, get AI insights`,
          image: resolvedImageWithDomain,
        },
        image: {
          alt: "Aero — Publish prototypes, run user tests, get AI insights",
        },
      }}
    />
    <script
      src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"
      defer></script>
  </head>
  <body>
    <Navbar />
    <main id="main-content" tabindex="-1">
      <slot />
    </main>
    <Footer />
    <style is:global>
      img {
        content-visibility: auto;
      }
    </style>
  </body>
</html>
