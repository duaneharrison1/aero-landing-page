---
interface Props {
  size?: "md" | "lg";
  block?: boolean;
  style?: "outline" | "primary" | "inverted";
  class?: string;
  [x: string]: any;
}

const {
  size = "md",
  style = "primary",
  block,
  class: className,
  ...rest
} = Astro.props;

// Sizing is owned by the shared button styles in global.css. "lg" opts
// into the larger CTA size (.btn-lg); "md" keeps the base button size.
const sizes = {
  md: "",
  lg: "btn-lg",
};

// Shares the Aero glass button treatment from global.css.
const styles = {
  outline: "btn-secondary",
  primary: "btn-primary",
  inverted: "btn-primary",
};
---

<button
  {...rest}
  class:list={[
    "text-center focus-visible:ring-2 ring-offset-2 ring-gray-200",
    block && "w-full",
    sizes[size],
    styles[style] ?? styles.primary,
    className,
  ]}
  ><slot />
</button>
