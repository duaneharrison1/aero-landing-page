---
interface Props {
  href: string;
  size?: "md" | "lg";
  block?: boolean;
  style?: "outline" | "primary" | "inverted" | "muted";
  class?: string;
  [x: string]: any;
}

const {
  href,
  block,
  size = "lg",
  style = "primary",
  class: className,
  ...rest
} = Astro.props;

const sizes = {
  lg: "px-5 py-2.5",
  md: "px-4 py-2",
};

// All variants now share the Aero glass button treatment defined in
// global.css (.btn-primary / .btn-secondary). Primary and inverted use the
// accent fill; outline and muted use the light-tinted secondary.
const styles = {
  outline: "btn-secondary",
  primary: "btn-primary",
  inverted: "btn-primary",
  muted: "btn-secondary",
};
---

<a
  href={href}
  {...rest}
  class:list={[
    "text-center focus-visible:ring-2 ring-offset-2 ring-gray-200",
    block && "w-full",
    sizes[size],
    styles[style],
    className,
  ]}
  ><slot />
</a>
