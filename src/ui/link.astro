---
interface Props {
  href: string;
  size?: "md" | "lg";
  block?: boolean;
  style?: "outline" | "primary" | "inverted" | "muted";
  class?: string;
  [x: string]: any;
}

const {
  href,
  block,
  size = "lg",
  style = "primary",
  class: className,
  ...rest
} = Astro.props;

const sizes = {
  lg: "px-5 py-2.5 text-sm",
  md: "px-4 py-2 text-sm",
};

const styles = {
  outline: "bg-[rgba(61,120,176,0.14)] text-[#3D78B0] hover:bg-[rgba(61,120,176,0.22)] border border-[#3D78B0]",
  primary: "bg-[#3D78B0] text-white hover:bg-[#2F6499] shadow-[0_2px_8px_rgba(61,120,176,0.15)] border border-transparent",
  inverted: "bg-white text-[#3D78B0] border border-[#3D78B0]",
  muted: "bg-[#F4F5F8] text-[#6B6F76] hover:bg-[#E8EAED] border border-transparent",
};
---

<a
  href={href}
  {...rest}
  class:list={[
    "rounded-lg font-semibold text-center transition-colors duration-150 focus-visible:ring-2 ring-offset-2 ring-[rgba(61,120,176,0.3)] inline-flex items-center justify-center",
    block && "w-full",
    sizes[size],
    styles[style],
    className,
  ]}
><slot />
</a>
