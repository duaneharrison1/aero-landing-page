---
const APP_URL = "https://aeroapp.ai/auth";
---
<footer class="bg-[#F9FAFB] border-t border-subtle pt-10 pb-5 mt-20">
  <div class="max-w-[1440px] mx-auto px-6 md:px-12">
    <div class="grid grid-cols-1 md:grid-cols-5 gap-6 md:gap-8 pb-8">
      <div>
        <a href="/" class="flex items-center select-none mb-3" aria-label="Aero home">
          <span class="aero-wordmark" style="font-size:22px;">Aero.</span>
        </a>
        <p class="text-[#6B6F76] text-sm max-w-xs leading-relaxed">
          Publish prototypes to live URLs and run recorded user tests with AI
          insights.
        </p>
      </div>
      <div>
        <h3 class="font-semibold mb-3 text-[#1D1D1F]">Product</h3>
        <ul class="space-y-2 text-[#6B6F76] text-base">
          <li><a href="/how-it-works" class="hover:text-[#1D1D1F]">How it works</a></li>
          <li><a href="/pricing" class="hover:text-[#1D1D1F]">Pricing</a></li>
        </ul>
      </div>
      <div>
        <h3 class="font-semibold mb-3 text-[#1D1D1F]">Features</h3>
        <ul class="space-y-2 text-[#6B6F76] text-base">
          <li><a href="/features/custom-domain" class="hover:text-[#1D1D1F]">Custom domain</a></li>
          <li><a href="/features/responsive-design" class="hover:text-[#1D1D1F]">Responsive design</a></li>
          <li><a href="/features/code-conversion" class="hover:text-[#1D1D1F]">Code conversion</a></li>
        </ul>
      </div>
      <div>
        <h3 class="font-semibold mb-3 text-[#1D1D1F]">Resources</h3>
        <ul class="space-y-2 text-[#6B6F76] text-base">
          <li><a href="/blog" class="hover:text-[#1D1D1F]">Blog</a></li>
          <li><a href="/about" class="hover:text-[#1D1D1F]">About</a></li>
          <li><a href="/contact" class="hover:text-[#1D1D1F]">Contact</a></li>
        </ul>
      </div>
      <div>
        <h3 class="font-semibold mb-3 text-[#1D1D1F]">Get started</h3>
        <ul class="space-y-2 text-[#6B6F76] text-base">
          <li><a href={APP_URL} class="hover:text-[#1D1D1F]">Sign in</a></li>
          <li><a href={APP_URL} class="hover:text-[#1D1D1F]">Create an account</a></li>
        </ul>
      </div>
    </div>
    <hr class="border-subtle mb-6" />
    <div class="text-center text-[#8E8E93] text-sm pb-2">
      © 2026 Aero. All rights reserved.
    </div>
  </div>
</footer>
