---
const APP_URL = "https://aeroapp.ai";
---

<header class="w-full">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-5">
    <a href={APP_URL} class="text-xl font-bold tracking-tight text-[var(--aero-text)]">
      Aero
    </a>
    <nav class="flex items-center gap-4 sm:gap-6">
      <a
        href={APP_URL}
        class="text-sm font-medium text-[var(--aero-muted)] transition hover:text-[var(--aero-text)]"
      >
        Sign in
      </a>
      <a href={APP_URL} class="btn-primary text-sm">Get started</a>
    </nav>
  </div>
</header>
