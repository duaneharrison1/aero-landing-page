---
const hostFeatures = [
  {
    title: "Drag and drop",
    description: "Drop a folder or zip of static files and your prototype is live in seconds. No config, no CLI, no deploy pipeline.",
  },
  {
    title: "AI agent via MCP",
    description: "Connect your Claude agent with one command. Your agent publishes directly to Aero mid-conversation, no human in the loop.",
  },
  {
    title: "Figma link",
    description: "Paste a Figma prototype link and Aero hosts it at a permanent URL your team and testers can reach.",
  },
  {
    title: "Instant live URLs & versioning",
    description: "Every publish gets a unique URL. Previous versions stay accessible so you can compare iterations or share a specific build.",
  },
];

const testFeatures = [
  {
    title: "Task-based tests",
    description: "Define the tasks you want testers to attempt on your live hosted prototype. No external tool, no redirect.",
  },
  {
    title: "Screen and voice recording",
    description: "Every session captures the tester's screen and microphone. You see exactly what they did and hear what they thought.",
  },
  {
    title: "Transcripts and AI insights",
    description: "Aero transcribes each session and runs AI analysis. Your agent receives structured findings it can act on immediately.",
  },
];
---

<div id="features" class="mt-16 md:mt-24 scroll-mt-20">
  {/* Host section */}
  <div class="mb-20">
    <div class="flex items-center gap-3 mb-3">
      <span class="inline-flex items-center justify-center w-8 h-8 rounded-md bg-[rgba(61,120,176,0.08)] text-[#3D78B0]">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73L13 2.27a2 2 0 0 0-2 0L4 6.27A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
      </span>
      <span class="text-sm font-semibold text-[#3D78B0] uppercase tracking-wider">Host</span>
    </div>
    <h2 class="text-2xl md:text-3xl font-bold text-[#1D1D1F] mb-2">
      Publish a prototype in seconds
    </h2>
    <p class="text-[#6B6F76] text-base md:text-lg mb-8 max-w-xl">
      Three paths to a live URL: drag-drop, your AI agent, or a Figma link. Every publish is versioned and permanent.
    </p>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {hostFeatures.map((item) => (
        <div class="glass-card p-6">
          <h3 class="font-semibold text-[#1D1D1F] text-base mb-1">{item.title}</h3>
          <p class="text-[#6B6F76] text-sm leading-relaxed">{item.description}</p>
        </div>
      ))}
    </div>
  </div>

  {/* Test section */}
  <div>
    <div class="flex items-center gap-3 mb-3">
      <span class="inline-flex items-center justify-center w-8 h-8 rounded-md bg-[rgba(61,120,176,0.08)] text-[#3D78B0]">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
      </span>
      <span class="text-sm font-semibold text-[#3D78B0] uppercase tracking-wider">Test</span>
    </div>
    <h2 class="text-2xl md:text-3xl font-bold text-[#1D1D1F] mb-2">
      Run real user tests on what you just shipped
    </h2>
    <p class="text-[#6B6F76] text-base md:text-lg mb-8 max-w-xl">
      Task-based tests on your live hosted prototype. Real people, real recordings, AI-synthesized findings your agent can read.
    </p>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      {testFeatures.map((item) => (
        <div class="glass-card p-6">
          <h3 class="font-semibold text-[#1D1D1F] text-base mb-1">{item.title}</h3>
          <p class="text-[#6B6F76] text-sm leading-relaxed">{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</div>
