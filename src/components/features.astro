---
// Aero feature sections: Host and Test — the build-host-test-insight loop.
import Tick from "../ui/icons/tick.astro";

const groups = [
  {
    label: "Host",
    title: "Publish prototypes to live URLs",
    description:
      "Get a static site or prototype online in seconds, however you build it.",
    points: [
      "Publish by drag-and-drop, from an AI agent over MCP, or from a Figma link",
      "Instant live URLs you can share with anyone",
      "Versioning so you can update and roll back",
    ],
  },
  {
    label: "Test",
    title: "Run real user tests on what you shipped",
    description:
      "Turn any hosted prototype into a recorded, task-based user test.",
    points: [
      "Task-based tests on your real, live prototype",
      "Screen and voice recording of every session",
      "Transcripts plus AI insights, handed back automatically",
    ],
  },
];
---

<div class="mt-10 md:mt-0">
  <h2
    class="text-3xl md:text-4xl lg:text-5xl font-bold lg:tracking-tight text-center text-[#1D1D1F]">
    Build, host, test, learn
  </h2>
  <p class="text-base md:text-lg mt-3 md:mt-4 text-[#6B6F76] text-center max-w-2xl mx-auto">
    Aero closes the loop: publish a prototype to a live URL, then put it in front
    of real people and get the insights back.
  </p>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8 mt-8 md:mt-12">
    {
      groups.map((group) => (
        <div class="content-card p-8 md:p-10 text-left">
          <span class="inline-block text-xs font-semibold uppercase tracking-wide text-[#3D78B0] bg-[rgba(61,120,176,0.08)] rounded px-3 py-1 mb-4">
            {group.label}
          </span>
          <h3 class="font-bold text-2xl md:text-3xl text-[#1D1D1F] mb-2">
            {group.title}
          </h3>
          <p class="text-[#6B6F76] text-base md:text-lg leading-relaxed mb-6">
            {group.description}
          </p>
          <ul class="space-y-3">
            {group.points.map((point) => (
              <li class="flex items-start gap-3 text-[#1D1D1F] text-base">
                <Tick class="text-[#3D78B0] w-5 h-5 mt-0.5 flex-shrink-0" />
                <span>{point}</span>
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>
</div>
