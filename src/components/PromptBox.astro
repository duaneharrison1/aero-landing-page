---
const command =
  'claude mcp add --transport http aero https://aeroapp.ai/api/mcp --header "Authorization: Bearer YOUR_TOKEN"';
const instruction = "Then publish this project to Aero and create a user test for it.";
const copyText = command + "\n\n" + instruction;
---

<div class="mx-auto w-full max-w-3xl">
  <div class="relative rounded-2xl bg-ink p-5 text-left shadow-xl sm:p-6">
    <button
      type="button"
      data-copy={copyText}
      class="copy-btn absolute right-4 top-4 inline-flex items-center gap-1.5 rounded-md border border-white/15 bg-white/5 px-2.5 py-1.5 text-xs font-medium text-white/80 transition hover:bg-white/10"
      aria-label="Copy command"
    >
      <span class="copy-label">Copy</span>
    </button>
    <pre class="overflow-x-auto pr-16 font-mono text-sm leading-relaxed text-[#e6e8f2]"><code>{command}</code></pre>
    <p class="mt-4 font-mono text-sm leading-relaxed text-[#aeb4cc]">{instruction}</p>
  </div>
  <p class="mt-3 text-sm text-[var(--aero-muted)]">Sign up free to get your token.</p>
</div>

<script>
  document.querySelectorAll(".copy-btn").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const text = btn.getAttribute("data-copy") || "";
      const label = btn.querySelector(".copy-label");
      const original = label ? label.textContent : "Copy";
      try {
        if (navigator.clipboard && window.isSecureContext) {
          await navigator.clipboard.writeText(text);
        } else {
          const ta = document.createElement("textarea");
          ta.value = text;
          ta.style.position = "fixed";
          ta.style.opacity = "0";
          document.body.appendChild(ta);
          ta.select();
          document.execCommand("copy");
          document.body.removeChild(ta);
        }
        if (label) label.textContent = "Copied";
        btn.classList.add("text-white");
        setTimeout(() => {
          if (label) label.textContent = original;
          btn.classList.remove("text-white");
        }, 2000);
      } catch (err) {
        if (label) label.textContent = "Press Ctrl+C";
        setTimeout(() => {
          if (label) label.textContent = original;
        }, 2000);
      }
    });
  });
</script>
