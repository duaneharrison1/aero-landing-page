---
const APP_URL = "https://aeroapp.ai";
const mcpCommand =
  'claude mcp add --transport http aero https://aeroapp.ai/api/mcp --header "Authorization: Bearer YOUR_TOKEN"';
---

<main
  class="w-full grid grid-cols-1 lg:grid-cols-2 items-center pt-16 pb-8 md:pt-20 md:pb-24 gap-8 lg:gap-12">
  <div class="w-full text-left max-w-full lg:max-w-[920px]">
    <h1
      class="font-bold tracking-tight text-[#1D1D1F] leading-[1.1] break-words text-3xl sm:text-4xl md:text-5xl lg:text-6xl">
      The only place an AI agent can publish a prototype and get real humans
      testing it.
    </h1>
    <p class="text-base sm:text-lg mt-6 text-[#6B6F76] max-w-xl">
      One conversation: your agent builds, publishes to a live URL, and sets up
      a user test. Real people try it, their screen and voice recorded. AI hands
      your agent the insights.
    </p>
    <div
      class="mt-8 flex flex-col sm:flex-row gap-4 lg:justify-start justify-center">
      <a
        href={APP_URL}
        class="btn-primary btn-lg">
        Get started free
      </a>
      <a
        href="/how-it-works"
        class="btn-secondary btn-lg">
        See how it works
      </a>
    </div>
  </div>

  {/* Dark mono MCP prompt box */}
  <div class="flex w-full justify-center lg:justify-end mt-10 lg:mt-0">
    <div class="prompt-box w-full max-w-md p-5 text-sm">
      <div class="flex items-center justify-between mb-3">
        <span class="text-[#8E8E93] text-xs font-medium uppercase tracking-wide"
          >Connect your agent</span
        >
        <button
          id="copy-mcp-btn"
          type="button"
          data-command={mcpCommand}
          class="text-xs font-medium text-[#E6E8EC] bg-white/10 hover:bg-white/20 rounded px-3 py-1 transition-colors">
          Copy
        </button>
      </div>
      <pre
        class="whitespace-pre-wrap break-words leading-relaxed text-[#E6E8EC] m-0"><code>{mcpCommand}</code></pre>
      <p class="mt-4 text-[#B7BAC2] leading-relaxed">
        Then publish this project to Aero and create a user test for it.
      </p>
      <p class="mt-3 text-[#8E8E93] text-xs">
        Sign up free to get your token.
      </p>
    </div>
  </div>
</main>

<script>
  const copyBtn = document.getElementById("copy-mcp-btn");
  if (copyBtn) {
    copyBtn.addEventListener("click", async () => {
      const command = copyBtn.getAttribute("data-command") || "";
      try {
        await navigator.clipboard.writeText(command);
        const original = copyBtn.textContent;
        copyBtn.textContent = "Copied";
        setTimeout(() => {
          copyBtn.textContent = original;
        }, 2000);
      } catch (e) {
        console.error("Copy failed", e);
      }
    });
  }
</script>
