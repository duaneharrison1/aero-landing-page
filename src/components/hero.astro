---
---

<main class="w-full pt-16 pb-8 md:pt-24 md:pb-20">
  {/* Hero text */}
  <div class="max-w-3xl mx-auto text-center mb-12">
    <h1
      class="font-bold tracking-tight text-[#1D1D1F] leading-[1.08] text-3xl sm:text-4xl md:text-5xl lg:text-[3.25rem]">
      The only place an AI agent can publish a prototype and get real humans testing it.
    </h1>
    <p class="text-base sm:text-lg mt-6 text-[#6B6F76] max-w-2xl mx-auto leading-relaxed">
      One conversation: your agent builds, publishes to a live URL, and sets up a user test.
      Real people try it, their screen and voice recorded. AI hands your agent the insights.
    </p>
    <div class="mt-8 flex flex-col sm:flex-row gap-3 justify-center">
      <a
        href="https://aeroapp.ai"
        class="inline-flex items-center justify-center gap-2 bg-[#3D78B0] text-white font-semibold text-base px-6 py-3 rounded-lg shadow-[0_2px_8px_rgba(61,120,176,0.15)] hover:bg-[#2F6499] transition-colors duration-150"
      >
        Get started free
      </a>
      <a
        href="/#features"
        class="inline-flex items-center justify-center gap-2 bg-[rgba(61,120,176,0.14)] text-[#3D78B0] font-semibold text-base px-6 py-3 rounded-lg hover:bg-[rgba(61,120,176,0.22)] transition-colors duration-150"
      >
        See how it works
      </a>
    </div>
  </div>

  {/* MCP prompt box */}
  <div class="max-w-2xl mx-auto">
    <div
      class="rounded-lg overflow-hidden"
      style="background:#16181F;"
    >
      <div class="flex items-center justify-between px-4 pt-4 pb-2">
        <span class="text-[#8E8E93] text-xs font-mono">Terminal</span>
        <button
          id="copy-mcp-cmd"
          class="text-xs text-[#8E8E93] hover:text-white font-medium transition-colors duration-150 flex items-center gap-1"
          aria-label="Copy command"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
          Copy
        </button>
      </div>
      <div class="px-4 pb-4">
        <pre class="text-sm font-mono text-[#E5E7EB] whitespace-pre-wrap break-all leading-relaxed"><span class="text-[#8E8E93]">$</span> <span id="mcp-cmd-text">claude mcp add --transport http aero https://aeroapp.ai/api/mcp --header "Authorization: Bearer YOUR_TOKEN"</span></pre>
        <p class="mt-3 text-sm font-mono text-[#E5E7EB]">Then publish this project to Aero and create a user test for it.</p>
        <p class="mt-2 text-xs text-[#6B6F76]">Sign up free to get your token.</p>
      </div>
    </div>
  </div>
</main>

<script>
  const btn = document.getElementById('copy-mcp-cmd');
  const cmdText = document.getElementById('mcp-cmd-text');
  if (btn && cmdText) {
    btn.addEventListener('click', async () => {
      const text = 'claude mcp add --transport http aero https://aeroapp.ai/api/mcp --header "Authorization: Bearer YOUR_TOKEN"';
      try {
        await navigator.clipboard.writeText(text);
        btn.textContent = 'Copied!';
        setTimeout(() => {
          btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg> Copy';
        }, 2000);
      } catch {}
    });
  }
</script>
